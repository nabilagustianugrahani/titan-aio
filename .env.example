# ── HF Spaces Configuration ────────────────────────
# HF Spaces provides PostgreSQL automatically:
DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname
# For local dev (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./data/titan.db

# HF Spaces auto-sets PORT=7860, HOST=0.0.0.0
# PORT=7860
# HOST=0.0.0.0

# ── Keep-Alive ──────────────────────────────────────
# Set up cron-job.org to ping /keepalive every 5 min
# Space URL: https://<user>-<space>.hf.space

# ── Existing vars ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0
GDRIVE_CREDENTIALS_FILE=./credentials/gdrive.json
GDRIVE_FOLDER_ID=
NOTION_TOKEN=
NOTION_CAMPAIGN_DB=
NOTION_KNOWLEDGE_DB=
NOTION_TASKS_DB=
MONGODB_URI=
MONGODB_DB_NAME=titan_aio
HF_TOKEN=
SCRAPINGBEE_API_KEY=
GOOGLE_AI_API_KEY=
HF_SCRAPER_URL=https://hf.space/titan/browser_scraper
