# ══════════════════════════════════════════════════════════
# TITAN AIO — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
# APP_NAME=TITAN AIO
# DEBUG=false
# LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────
# Default: SQLite for dev
DATABASE_URL=sqlite+aiosqlite:///./data/titan.db
# HF Spaces (auto-set via secrets):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname

# HF Spaces auto-sets PORT=7860, HOST=0.0.0.0
# PORT=7860
# HOST=0.0.0.0

# ── S3 / Object Storage ─────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=titan-assets
S3_REGION=auto

# ── ChromaDB (vector store) ─────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Google Drive ─────────────────────────────────────────
GDRIVE_CREDENTIALS_FILE=./credentials/gdrive.json
GDRIVE_FOLDER_ID=

# ── HuggingFace ──────────────────────────────────────────
HF_TOKEN=
HF_SCRAPER_URL=https://hf.space/titan/browser_scraper

# ── Generation Models ────────────────────────────────────
IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
VIDEO_MODEL=Wan-AI/Wan2.2-T2V-14B

# ── LoRA Policy ──────────────────────────────────────────
# LORA_MIN_USAGE=20

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://your-vps.com/webhook

# ── Growth Thresholds ────────────────────────────────────
# GROWTH_SCALE_ROI=2.0
# GROWTH_KILL_ROI=0.5
# GROWTH_KILL_CONSECUTIVE=2

# ── Notion ───────────────────────────────────────────────
NOTION_TOKEN=
NOTION_CAMPAIGN_DB=
NOTION_KNOWLEDGE_DB=
NOTION_TASKS_DB=

# ── MongoDB Atlas ────────────────────────────────────────
MONGODB_URI=
MONGODB_DB_NAME=titan_aio
MONGODB_PUBLIC_KEY=
MONGODB_PRIVATE_KEY=
MONGODB_PROJECT_ID=
MONGODB_CLIENT_ID=
MONGODB_CLIENT_SECRET=

# ── Timezone ─────────────────────────────────────────────
# VPS_TIMEZONE=Asia/Kolkata
# USER_TIMEZONE=Asia/Jakarta

# ── TikTok API (Production) ──────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── TikTok API (Sandbox) ─────────────────────────────────
TIKTOK_SANDBOX_CLIENT_KEY=
TIKTOK_SANDBOX_CLIENT_SECRET=

# ── External APIs ────────────────────────────────────────
SCRAPINGBEE_API_KEY=
GOOGLE_AI_API_KEY=

# ── Zernio Social Media API (14+ platforms) ───────────────
# Zernio adalah unified API untuk posting, analytics, inbox di
# TikTok, Instagram, Twitter/X, Facebook, LinkedIn, YouTube,
# Pinterest, Reddit, Bluesky, Threads, Telegram, Snapchat, dll.
# Dapatkan API key: https://zernio.com/dashboard/api-keys
# ZERNIO_API_KEY=sk_...

# ── Keep-Alive ───────────────────────────────────────────
# Set up cron-job.org to ping /keepalive every 5 min
# Space URL: https://<user>-<space>.hf.space
